{
  "name": "docparse-ts-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Layout-aware document parsing for RAG. TypeScript-native.",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r --filter \"./packages/*\" run build",
    "typecheck": "pnpm -r --filter \"./packages/*\" exec tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "pnpm -r exec rm -rf dist .turbo node_modules/.cache",
    "changeset": "changeset",
    "release": "pnpm build && changeset publish",
    "bench": "pnpm --filter @docparse/bench start"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.10",
    "@types/node": "^22.10.2",
    "pdf-lib": "^1.17.1",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
