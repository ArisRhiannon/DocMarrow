{
  "name": "docmarrow",
  "version": "1.0.0",
  "description": "Pure TypeScript document parser for PDF → Markdown, JSON and RAG chunks.",
  "keywords": [
    "pdf",
    "markdown",
    "rag",
    "typescript",
    "document-parsing",
    "pdf-to-markdown",
    "layout-analysis",
    "llm",
    "chunking",
    "no-python"
  ],
  "license": "AGPL-3.0-or-later",
  "author": "ArisRhiannon",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "docmarrow": "./dist/cli.js"
  },
  "files": ["dist"],
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "fast-xml-parser": "^5.8.0",
    "fflate": "^0.8.3",
    "node-html-parser": "^7.1.0",
    "pdfjs-dist": "^4.10.38"
  },
  "devDependencies": {
    "@docmarrow/core": "workspace:*",
    "@docmarrow/docx": "workspace:*",
    "@docmarrow/html": "workspace:*",
    "@docmarrow/ooxml": "workspace:*",
    "@docmarrow/pdf": "workspace:*",
    "@docmarrow/pptx": "workspace:*",
    "@docmarrow/xlsx": "workspace:*"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ArisRhiannon/DocMarrow.git"
  },
  "homepage": "https://github.com/ArisRhiannon/DocMarrow#readme",
  "bugs": {
    "url": "https://github.com/ArisRhiannon/DocMarrow/issues"
  }
}
