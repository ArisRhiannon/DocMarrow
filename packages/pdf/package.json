{
  "name": "@docparse/pdf",
  "version": "0.1.0",
  "description": "pdfjs-dist backend for docparse: positioned text extraction per page.",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@docparse/core": "workspace:*",
    "pdfjs-dist": "^4.10.38"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ArisRhiannon/docparse.git",
    "directory": "packages/pdf"
  }
}
