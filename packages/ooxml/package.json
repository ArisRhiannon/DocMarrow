{
  "name": "@docmarrow/ooxml",
  "version": "1.0.0",
  "description": "Shared OOXML helpers for DocMarrow backends: order-preserving XML parsing and zip reading.",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "fast-xml-parser": "^5.8.0",
    "fflate": "^0.8.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ArisRhiannon/DocMarrow.git",
    "directory": "packages/ooxml"
  },
  "private": true
}
