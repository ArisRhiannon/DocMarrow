{
  "name": "@docmarrow/xlsx",
  "version": "1.0.0",
  "description": "XLSX (OOXML spreadsheet) backend for docmarrow: sheets to heading + table blocks.",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@docmarrow/core": "workspace:*",
    "@docmarrow/ooxml": "workspace:*"
  },
  "devDependencies": {
    "fflate": "^0.8.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ArisRhiannon/DocMarrow.git",
    "directory": "packages/xlsx"
  },
  "private": true
}
