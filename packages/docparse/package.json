{
  "name": "docparse-ts",
  "version": "1.0.0",
  "description": "Layout-aware PDF → Markdown + JSON + RAG chunks. TypeScript-native, no Python, no servers.",
  "keywords": [
    "pdf",
    "markdown",
    "rag",
    "typescript",
    "document-parsing",
    "pdf-to-markdown",
    "layout-analysis",
    "llm",
    "chunking",
    "no-python"
  ],
  "license": "AGPL-3.0-or-later",
  "author": "ArisRhiannon",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "docparse-ts": "./dist/cli.js"
  },
  "files": ["dist"],
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "fast-xml-parser": "^5.8.0",
    "fflate": "^0.8.3",
    "pdfjs-dist": "^4.10.38"
  },
  "devDependencies": {
    "@docparse/core": "workspace:*",
    "@docparse/docx": "workspace:*",
    "@docparse/pdf": "workspace:*"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ArisRhiannon/docparse-ts.git"
  },
  "homepage": "https://github.com/ArisRhiannon/docparse-ts#readme",
  "bugs": {
    "url": "https://github.com/ArisRhiannon/docparse-ts/issues"
  }
}
