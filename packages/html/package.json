{
  "name": "@docmarrow/html",
  "version": "1.0.0",
  "description": "HTML backend for docmarrow: parses HTML into headings, lists, tables, code, quotes and paragraphs.",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@docmarrow/core": "workspace:*",
    "node-html-parser": "^7.1.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ArisRhiannon/DocMarrow.git",
    "directory": "packages/html"
  },
  "private": true
}
